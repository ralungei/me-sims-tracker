{
  "name": "me-sims-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create me-sims-tracker",
    "db:migrate:local": "wrangler d1 execute me-sims-tracker --local --file=./migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute me-sims-tracker --remote --file=./migrations/0001_initial.sql"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250121.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.103.2"
  }
}
